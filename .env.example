YANDEX_API_KEY=your_yandex_cloud_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here

# DeepSeek V4 Flash model URI from Yandex AI Studio announcement:
# gpt://<folder_id>/deepseek-v4-flash
YANDEX_MODEL_NAME=deepseek-v4-flash
# YANDEX_MODEL_URI=gpt://your_folder_id_here/deepseek-v4-flash

# OpenAI-compatible chat completions endpoint.
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1

# Use Api-Key for service account API keys.
# Use Bearer if you pass an IAM token in YANDEX_API_KEY.
YANDEX_AUTH_SCHEME=Api-Key

YANDEX_TEMPERATURE=0.3
YANDEX_MAX_TOKENS=2000
YANDEX_TIMEOUT=120
YANDEX_DATA_LOGGING_ENABLED=false

GIGACHAT_CREDENTIALS=your_authorization_key_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
STORY_DIR=
